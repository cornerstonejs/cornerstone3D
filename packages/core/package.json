{
  "name": "@cornerstonejs/core",
  "version": "5.6.8",
  "description": "Cornerstone3D Core",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "repository": "https://github.com/cornerstonejs/cornerstone3D",
  "files": [
    "./dist/"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "default": "./dist/esm/index.js"
    },
    "./utilities": {
      "types": "./dist/esm/utilities/index.d.ts",
      "import": "./dist/esm/utilities/index.js",
      "default": "./dist/esm/utilities/index.js"
    },
    "./utilities/*": {
      "types": "./dist/esm/utilities/*.d.ts",
      "import": "./dist/esm/utilities/*.js",
      "default": "./dist/esm/utilities/*.js"
    },
    "./constants": {
      "types": "./dist/esm/constants/index.d.ts",
      "import": "./dist/esm/constants/index.js",
      "default": "./dist/esm/constants/index.js"
    },
    "./constants/*": {
      "types": "./dist/esm/constants/*.d.ts",
      "import": "./dist/esm/constants/*.js",
      "default": "./dist/esm/constants/*.js"
    },
    "./enums": {
      "types": "./dist/esm/enums/index.d.ts",
      "import": "./dist/esm/enums/index.js",
      "default": "./dist/esm/enums/index.js"
    },
    "./enums/*": {
      "types": "./dist/esm/enums/*.d.ts",
      "import": "./dist/esm/enums/*.js",
      "default": "./dist/esm/enums/*.js"
    },
    "./loaders": {
      "types": "./dist/esm/loaders/index.d.ts",
      "import": "./dist/esm/loaders/index.js",
      "default": "./dist/esm/loaders/index.js"
    },
    "./loaders/*": {
      "types": "./dist/esm/loaders/*.d.ts",
      "import": "./dist/esm/loaders/*.js",
      "default": "./dist/esm/loaders/*.js"
    },
    "./types": {
      "types": "./dist/esm/types/index.d.ts"
    },
    "./types/*": {
      "types": "./dist/esm/types/*.d.ts"
    },
    "./version": {
      "types": "./dist/esm/version.d.ts",
      "import": "./dist/esm/version.js",
      "default": "./dist/esm/version.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prebuild": "node ../../scripts/generate-version.js ./",
    "build:esm": "pnpm run prebuild && tsc --project ./tsconfig.json && tsc-alias -p ./tsconfig.json --resolve-full-paths && node ../../scripts/write-dist-esm-package-json.js ./",
    "build:esm:watch": "sh -c 'tsc-alias -p ./tsconfig.json --resolve-full-paths --watch & alias_pid=$!; node ../../scripts/write-dist-esm-package-json.js ./ --watch & writer_pid=$!; trap \"kill $alias_pid $writer_pid\" EXIT; tsc --project ./tsconfig.json --watch'",
    "clean": "rm -rf node_modules/.cache/storybook && shx rm -rf dist",
    "clean:deep": "pnpm run clean && shx rm -rf node_modules",
    "build": "pnpm run build:esm",
    "build:all": "pnpm run build:esm",
    "dev": "tsc --project ./tsconfig.json --watch --sourceMap --inlineSources",
    "api-check": "api-extractor --debug run ",
    "lint": "oxlint .",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@cornerstonejs/utils": "5.6.8",
    "@kitware/vtk.js": "36.4.2",
    "comlink": "4.4.2",
    "gl-matrix": "3.4.3",
    "loglevel": "1.9.2"
  },
  "devDependencies": {
    "@cornerstonejs/metadata": "5.6.8"
  },
  "peerDependencies": {
    "@cornerstonejs/metadata": "5.6.8",
    "@cornerstonejs/utils": "5.6.8"
  },
  "contributors": [
    {
      "name": "Cornerstone.js Contributors",
      "url": "https://github.com/orgs/cornerstonejs/people"
    }
  ],
  "license": "MIT",
  "funding": {
    "type": "individual",
    "url": "https://ohif.org/donate"
  }
}
