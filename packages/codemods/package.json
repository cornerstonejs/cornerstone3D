{
  "name": "@cornerstonejs/codemods",
  "version": "5.0.0-beta.1",
  "description": "Codemods for Cornerstone3D migrations",
  "keywords": [
    "cornerstone3d",
    "codemod",
    "jscodeshift"
  ],
  "repository": "https://github.com/cornerstonejs/cornerstone3D",
  "main": "./src/index.js",
  "bin": {
    "cornerstonejs-codemods": "./src/cli.js"
  },
  "files": [
    "src",
    "README.md"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node -e \"console.log('codemods package does not require a build step')\"",
    "build:esm": "yarn run build",
    "build:esm:watch": "yarn run build",
    "build:all": "yarn run build",
    "clean": "shx rm -rf dist",
    "clean:deep": "yarn run clean && shx rm -rf node_modules",
    "dev": "yarn run test --watch",
    "test": "jest --config ./jest.config.js",
    "lint": "oxlint .",
    "prepublishOnly": "yarn run test"
  },
  "dependencies": {
    "jscodeshift": "^17.3.0"
  },
  "contributors": [
    {
      "name": "Cornerstone.js Contributors",
      "url": "https://github.com/orgs/cornerstonejs/people"
    }
  ],
  "license": "MIT",
  "funding": {
    "type": "individual",
    "url": "https://ohif.org/donate"
  }
}
