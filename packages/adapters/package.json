{
  "name": "@cornerstonejs/adapters",
  "version": "5.4.14",
  "description": "Adapters for Cornerstone3D to/from formats including DICOM SR and others",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "files": [
    "dist"
  ],
  "directories": {
    "build": "dist"
  },
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "default": "./dist/esm/index.js"
    },
    "./cornerstone": {
      "types": "./dist/esm/adapters/Cornerstone/index.d.ts",
      "import": "./dist/esm/adapters/Cornerstone/index.js",
      "default": "./dist/esm/adapters/Cornerstone/index.js"
    },
    "./cornerstone/*": {
      "types": "./dist/esm/adapters/Cornerstone/*.d.ts",
      "import": "./dist/esm/adapters/Cornerstone/*.js",
      "default": "./dist/esm/adapters/Cornerstone/*.js"
    },
    "./cornerstone3D": {
      "types": "./dist/esm/adapters/Cornerstone3D/index.d.ts",
      "import": "./dist/esm/adapters/Cornerstone3D/index.js",
      "default": "./dist/esm/adapters/Cornerstone3D/index.js"
    },
    "./cornerstone3D/*": {
      "types": "./dist/esm/adapters/Cornerstone3D/*.d.ts",
      "import": "./dist/esm/adapters/Cornerstone3D/*.js",
      "default": "./dist/esm/adapters/Cornerstone3D/*.js"
    },
    "./enums": {
      "types": "./dist/esm/adapters/enums/index.d.ts",
      "import": "./dist/esm/adapters/enums/index.js",
      "default": "./dist/esm/adapters/enums/index.js"
    },
    "./enums/*": {
      "types": "./dist/esm/adapters/enums/*.d.ts",
      "import": "./dist/esm/adapters/enums/*.js",
      "default": "./dist/esm/adapters/enums/*.js"
    },
    "./helpers": {
      "types": "./dist/esm/adapters/helpers/index.d.ts",
      "import": "./dist/esm/adapters/helpers/index.js",
      "default": "./dist/esm/adapters/helpers/index.js"
    },
    "./helpers/*": {
      "types": "./dist/esm/adapters/helpers/*.d.ts",
      "import": "./dist/esm/adapters/helpers/*.js",
      "default": "./dist/esm/adapters/helpers/*.js"
    },
    "./version": {
      "types": "./dist/esm/version.d.ts",
      "import": "./dist/esm/version.js",
      "default": "./dist/esm/version.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "jest --testTimeout 60000",
    "build": "rollup -c rollup.config.mjs && tsc-alias -p ./tsconfig.json --resolve-full-paths && node ../../scripts/write-dist-esm-package-json.js ./",
    "build:esm": "pnpm run prebuild && rollup -c rollup.config.mjs && tsc-alias -p ./tsconfig.json --resolve-full-paths && node ../../scripts/write-dist-esm-package-json.js ./",
    "build:esm:watch": "sh -c 'tsc-alias -p ./tsconfig.json --resolve-full-paths --watch & alias_pid=$!; node ../../scripts/write-dist-esm-package-json.js ./ --watch & writer_pid=$!; trap \"kill $alias_pid $writer_pid\" EXIT; rollup --watch -c rollup.config.mjs'",
    "clean": "rm -rf node_modules/.cache/storybook && shx rm -rf dist",
    "clean:deep": "pnpm run clean && shx rm -rf node_modules",
    "dev": "rollup --watch  -c rollup.config.mjs",
    "build:all": "pnpm run build",
    "api-check": "echo 'No API check for this package'",
    "start": "rollup --watch -c rollup.config.mjs",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,css,md}\" \"test/**/*.{js,jsx,ts,tsx,json,css,md}\" \"examples/**/*.{js,jsx,ts,tsx,json,css,md}\" \"*.{js,mjs,json,md}\"",
    "lint": "oxlint .",
    "prebuild": "node ../../scripts/generate-version.js ./"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cornerstonejs/cornerstone3D.git"
  },
  "author": "@cornerstonejs adapters package",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/cornerstonejs/cornerstone3D/issues"
  },
  "homepage": "https://github.com/cornerstonejs/cornerstone3D/blob/main/packages/adapters/README.md",
  "dependencies": {
    "@babel/runtime-corejs2": "7.26.10",
    "buffer": "6.0.3",
    "dcmjs": "0.52.0",
    "gl-matrix": "3.4.3",
    "ndarray": "1.0.19"
  },
  "devDependencies": {
    "@cornerstonejs/core": "5.4.14",
    "@cornerstonejs/tools": "5.4.14"
  },
  "peerDependencies": {
    "@cornerstonejs/core": "5.4.14",
    "@cornerstonejs/tools": "5.4.14"
  }
}
